<!DOCTYPE html>
<html lang="da">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Den Biodynamiske App</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Cinzel:wght@300;400&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="css/style.css">

  <!-- Marked.js from CDN -->
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>
<body>

  <!-- Dark mode toggle -->
  <button class="theme-toggle" aria-label="Skift tema"></button>

  <div class="container" id="app-container">
    <!-- Content loaded dynamically via JavaScript -->
    <div style="text-align: center; padding: 60px 20px; color: var(--text-secondary);">
      <p>Indlæser...</p>
    </div>
  </div>

  <script>
    // Farvegradering per begreb (1 = dybest, 2 = mellem, 3 = lysest)
    const BEGREB_DYBDE = {
      // Dybest (mørkest)
      'dynamisk-stilhed': 1,
      'breath-of-life': 1,
      'primary-respiration': 1,
      // Mellemdybt (midt-toner)
      'midtlinjen': 2,
      'the-health': 2,
      'transmutation': 2,
      'ignition': 2,
      'the-neutral': 2,
      'den-iboende-behandlingsplan': 2,
      'fluid-body': 2,
      'wholeness': 2,
      'stillpoints': 2,
      // Lysere (nærmere overfladen)
      'motion-present': 3,
      'fulcrum': 3,
      'automatic-shifting': 3,
      'potency': 3,
      'axial-fluctuations': 3,
      'the-lesion-field': 3
    };

    // Gradient-farver per dybde-niveau
    const GRADIENT_COLORS = {
      1: { // Dybest
        stops: ['#B8C4D1', '#7C8FA5', '#4A5E72', '#2B3C4F']
      },
      2: { // Mellem (standard fra design-system)
        stops: ['#C9D4DE', '#8FA3B8', '#5E748A', '#3A4A5C']
      },
      3: { // Lysere
        stops: ['#DDE4EB', '#A8B8C8', '#7C8FA5', '#5E748A']
      }
    };

    // Map fra id til filnavn (baseret på filnavne i content/begreber/)
    // TODO: verificér med Niklas — skal dette map flyttes til en separat JSON-fil senere?
    const BEGREB_FILES = {
      'dynamisk-stilhed': '01-dynamisk-stilhed.md',
      'breath-of-life': '02-breath-of-life.md',
      'primary-respiration': '03-primary-respiration.md',
      'midtlinjen': '04-midtlinjen.md',
      'the-health': '05-the-health.md',
      'motion-present': '06-motion-present.md',
      'fulcrum': '07-fulcrum.md',
      'stillpoints': '08-stillpoints.md',
      'transmutation': '09-transmutation.md',
      'the-neutral': '10-the-neutral.md',
      'automatic-shifting': '11-automatic-shifting.md',
      'den-iboende-behandlingsplan': '12-den-iboende-behandlingsplan.md',
      'fluid-body': '13-fluid-body.md',
      'the-lesion-field': '14-the-lesion-field.md',
      'potency': '15-potency.md',
      'ignition': '16-ignition.md',
      'axial-fluctuations': '17-axial-fluctuations.md',
      'wholeness': '18-wholeness.md'
    };

    // Gruppe-labels (baseret på design-system)
    const GRUPPE_LABELS = {
      'principiel': 'PRINCIPIEL',
      'behandlings-faenomen': 'BEHANDLINGS-FÆNOMEN',
      'patologisk': 'PATOLOGISK'
    };

    // Parse YAML frontmatter (simple regex-baseret parser)
    function parseFrontmatter(markdown) {
      const frontmatterRegex = /^---\s*\n([\s\S]*?)\n---\s*\n([\s\S]*)$/;
      const match = markdown.match(frontmatterRegex);

      if (!match) {
        return { frontmatter: {}, content: markdown };
      }

      const frontmatterText = match[1];
      const content = match[2];

      const frontmatter = {};
      frontmatterText.split('\n').forEach(line => {
        const colonIndex = line.indexOf(':');
        if (colonIndex > -1) {
          const key = line.substring(0, colonIndex).trim();
          let value = line.substring(colonIndex + 1).trim();
          // Remove quotes if present
          value = value.replace(/^["']|["']$/g, '');
          frontmatter[key] = value;
        }
      });

      return { frontmatter, content };
    }

    // Parse markdown content into sections
    function parseContent(markdownContent) {
      const sections = {};
      const lines = markdownContent.split('\n');
      let currentSection = null;
      let currentContent = [];

      lines.forEach(line => {
        if (line.startsWith('## ')) {
          // Save previous section
          if (currentSection) {
            sections[currentSection] = currentContent.join('\n').trim();
          }
          // Start new section
          currentSection = line.replace('## ', '').trim();
          currentContent = [];
        } else if (currentSection) {
          currentContent.push(line);
        }
      });

      // Save last section
      if (currentSection) {
        sections[currentSection] = currentContent.join('\n').trim();
      }

      return sections;
    }

    // Generate hero SVG motif (for now, hardcoded for Dynamisk Stilhed)
    function generateHeroSVG(begrebId) {
      // TODO: Load appropriate motif based on begrebId
      // For now, only dynamisk-stilhed has a custom motif
      if (begrebId === 'dynamisk-stilhed') {
        return `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 380 640" role="img" aria-label="Dynamisk Stilhed">

<defs>
<style>
@keyframes core-r { 0%, 100% { r: 36px; } 50% { r: 46px; } }
@keyframes aura-r { 0%, 100% { rx: 158px; ry: 158px; } 50% { rx: 182px; ry: 182px; } }
@keyframes dot-a { 0%, 100% { r: 0.65px; } 50% { r: 1.2px; } }
@keyframes dot-b { 0%, 100% { r: 0.55px; } 50% { r: 1.1px; } }
@keyframes dot-c { 0%, 100% { r: 0.45px; } 50% { r: 0.95px; } }
.core { animation: core-r 8s ease-in-out infinite; }
.aura { animation: aura-r 8s ease-in-out infinite; }
.d-a { animation: dot-a 8s ease-in-out infinite; }
.d-b { animation: dot-b 8s ease-in-out infinite; }
.d-c { animation: dot-c 8s ease-in-out infinite; }
@media (prefers-reduced-motion: reduce) {
  .core, .aura, .d-a, .d-b, .d-c { animation: none; }
}
</style>
<radialGradient id="well" cx="50%" cy="42%" r="65%">
<stop offset="0%" stop-color="#2a3847"/>
<stop offset="55%" stop-color="#1d2731"/>
<stop offset="100%" stop-color="#141b22"/>
</radialGradient>
<radialGradient id="core-g" cx="50%" cy="50%" r="50%">
<stop offset="0%" stop-color="#faf4e8" stop-opacity="1"/>
<stop offset="30%" stop-color="#f0e2c8" stop-opacity="0.6"/>
<stop offset="70%" stop-color="#d4b98f" stop-opacity="0.15"/>
<stop offset="100%" stop-color="#c9b8a0" stop-opacity="0"/>
</radialGradient>
<radialGradient id="aura-g" cx="50%" cy="50%" r="50%">
<stop offset="0%" stop-color="#e8dfcf" stop-opacity="0.28"/>
<stop offset="55%" stop-color="#a89880" stop-opacity="0.07"/>
<stop offset="100%" stop-color="#a89880" stop-opacity="0"/>
</radialGradient>
</defs>

<rect x="0" y="0" width="380" height="640" fill="url(#well)"/>

<ellipse class="aura" cx="190" cy="270" rx="170" ry="170" fill="url(#aura-g)"/>

<g fill="#faf4e8">
<circle class="d-a" cx="242" cy="218" r="1" opacity="0.8"/>
<circle class="d-a" cx="140" cy="310" r="0.9" opacity="0.72"/>
<circle class="d-b" cx="216" cy="340" r="0.7" opacity="0.65"/>
<circle class="d-b" cx="160" cy="222" r="0.9" opacity="0.7"/>
<circle class="d-a" cx="254" cy="294" r="0.8" opacity="0.72"/>
<circle class="d-c" cx="115" cy="265" r="0.7" opacity="0.6"/>
<circle class="d-b" cx="268" cy="248" r="0.8" opacity="0.68"/>
</g>

<circle class="core" cx="190" cy="270" r="42" fill="url(#core-g)"/>

</svg>
        `;
      }

      if (begrebId === 'breath-of-life') {
        return `
