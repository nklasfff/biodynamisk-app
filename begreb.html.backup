<stop offset="55%" stop-color="#a89880" stop-opacity="0.07"/>
<stop offset="100%" stop-color="#a89880" stop-opacity="0"/>
</radialGradient>
<radialGradient id="pearl-g-po" cx="50%" cy="50%" r="50%">
<stop offset="0%" stop-color="#ffffff" stop-opacity="1"/>
<stop offset="50%" stop-color="#faf4e8" stop-opacity="0.7"/>
<stop offset="100%" stop-color="#f0e2c8" stop-opacity="0"/>
</radialGradient>
</defs>

<rect x="0" y="0" width="380" height="640" fill="url(#well-po)"/>

<ellipse class="aura" cx="190" cy="270" rx="170" ry="170" fill="url(#aura-g-po)"/>

<g fill="url(#pearl-g-po)">
<circle class="p-a" cx="190" cy="208" r="1.2" opacity="0.95"/>
<circle class="p-a" cx="234" cy="226" r="1.2" opacity="0.95"/>
<circle class="p-a" cx="252" cy="270" r="1.2" opacity="0.95"/>
<circle class="p-a" cx="234" cy="314" r="1.2" opacity="0.95"/>
<circle class="p-a" cx="190" cy="332" r="1.2" opacity="0.95"/>
<circle class="p-a" cx="146" cy="314" r="1.2" opacity="0.95"/>
<circle class="p-a" cx="128" cy="270" r="1.2" opacity="0.95"/>
<circle class="p-a" cx="146" cy="226" r="1.2" opacity="0.95"/>

<circle class="p-b" cx="190" cy="178" r="1" opacity="0.8"/>
<circle class="p-b" cx="255" cy="205" r="1" opacity="0.8"/>
<circle class="p-b" cx="282" cy="270" r="1" opacity="0.8"/>
<circle class="p-b" cx="255" cy="335" r="1" opacity="0.8"/>
<circle class="p-b" cx="190" cy="362" r="1" opacity="0.8"/>
<circle class="p-b" cx="125" cy="335" r="1" opacity="0.8"/>
<circle class="p-b" cx="98" cy="270" r="1" opacity="0.8"/>
<circle class="p-b" cx="125" cy="205" r="1" opacity="0.8"/>

<circle class="p-c" cx="190" cy="145" r="0.9" opacity="0.65"/>
<circle class="p-c" cx="278" cy="182" r="0.9" opacity="0.65"/>
<circle class="p-c" cx="315" cy="270" r="0.9" opacity="0.65"/>
<circle class="p-c" cx="278" cy="358" r="0.9" opacity="0.65"/>
<circle class="p-c" cx="190" cy="395" r="0.9" opacity="0.65"/>
<circle class="p-c" cx="102" cy="358" r="0.9" opacity="0.65"/>
<circle class="p-c" cx="65" cy="270" r="0.9" opacity="0.65"/>
<circle class="p-c" cx="102" cy="182" r="0.9" opacity="0.65"/>
</g>

<circle class="core" cx="190" cy="270" r="42" fill="url(#core-g-po)"/>

</svg>
        `;
      }

      if (begrebId === 'ignition') {
        return `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 380 640" role="img" aria-label="Ignition">

<defs>
<style>
@keyframes core-r {
  0%, 100% { r: 34px; }
  50% { r: 52px; }
}
@keyframes aura-r {
  0%, 100% { rx: 155px; ry: 155px; opacity: 0.75; }
  50% { rx: 195px; ry: 195px; opacity: 1; }
}
@keyframes storm-top {
  0%, 100% {
    d: path("M 100 100 Q 140 170 190 228");
    stroke-width: 0.4px;
    opacity: 0.35;
  }
  50% {
    d: path("M 100 100 Q 140 170 190 228");
    stroke-width: 1.3px;
    opacity: 0.95;
  }
}
@keyframes storm-bot {
  0%, 100% {
    d: path("M 280 440 Q 240 370 190 312");
    stroke-width: 0.4px;
    opacity: 0.35;
  }
  50% {
    d: path("M 280 440 Q 240 370 190 312");
    stroke-width: 1.3px;
    opacity: 0.95;
  }
}
@keyframes storm-top-2 {
  0%, 100% {
    d: path("M 130 105 Q 160 180 190 235");
    stroke-width: 0.3px;
    opacity: 0.25;
  }
  50% {
    d: path("M 130 105 Q 160 180 190 235");
    stroke-width: 0.9px;
    opacity: 0.7;
  }
}
@keyframes storm-bot-2 {
  0%, 100% {
    d: path("M 250 435 Q 220 360 190 305");
    stroke-width: 0.3px;
    opacity: 0.25;
  }
  50% {
    d: path("M 250 435 Q 220 360 190 305");
    stroke-width: 0.9px;
    opacity: 0.7;
  }
}
@keyframes spark {
  0%, 100% { r: 2px; opacity: 0.3; }
  50% { r: 5px; opacity: 1; }
}
.core { animation: core-r 8s ease-in-out infinite; }
.aura { animation: aura-r 8s ease-in-out infinite; }
.s-top { animation: storm-top 8s ease-in-out infinite; }
.s-bot { animation: storm-bot 8s ease-in-out infinite; }
.s-top-2 { animation: storm-top-2 8s ease-in-out infinite; }
.s-bot-2 { animation: storm-bot-2 8s ease-in-out infinite; }
.spark { animation: spark 8s ease-in-out infinite; }
@media (prefers-reduced-motion: reduce) {
  .core, .aura, .s-top, .s-bot, .s-top-2, .s-bot-2, .spark { animation: none; }
}
</style>
<radialGradient id="well-ig" cx="50%" cy="42%" r="65%">
<stop offset="0%" stop-color="#2a3847"/>
<stop offset="55%" stop-color="#1d2731"/>
<stop offset="100%" stop-color="#141b22"/>
</radialGradient>
<radialGradient id="core-g-ig" cx="50%" cy="50%" r="50%">
<stop offset="0%" stop-color="#ffffff" stop-opacity="1"/>
<stop offset="30%" stop-color="#faf4e8" stop-opacity="0.8"/>
<stop offset="70%" stop-color="#f0e2c8" stop-opacity="0.25"/>
<stop offset="100%" stop-color="#d4b98f" stop-opacity="0"/>
</radialGradient>
<radialGradient id="aura-g-ig" cx="50%" cy="50%" r="50%">
<stop offset="0%" stop-color="#faf4e8" stop-opacity="0.32"/>
<stop offset="55%" stop-color="#a89880" stop-opacity="0.08"/>
<stop offset="100%" stop-color="#a89880" stop-opacity="0"/>
</radialGradient>
<radialGradient id="spark-g-ig" cx="50%" cy="50%" r="50%">
<stop offset="0%" stop-color="#ffffff" stop-opacity="1"/>
<stop offset="50%" stop-color="#faf4e8" stop-opacity="0.6"/>
<stop offset="100%" stop-color="#f0e2c8" stop-opacity="0"/>
</radialGradient>
</defs>

<rect x="0" y="0" width="380" height="640" fill="url(#well-ig)"/>

<ellipse class="aura" cx="190" cy="270" rx="170" ry="170" fill="url(#aura-g-ig)"/>

<g fill="none" stroke="#faf4e8" stroke-linecap="round">
<path class="s-top" d="M 100 100 Q 140 170 190 228"/>
<path class="s-top-2" d="M 130 105 Q 160 180 190 235"/>
<path class="s-bot" d="M 280 440 Q 240 370 190 312"/>
<path class="s-bot-2" d="M 250 435 Q 220 360 190 305"/>
</g>

<circle class="core" cx="190" cy="270" r="42" fill="url(#core-g-ig)"/>

<circle class="spark" cx="190" cy="270" r="2" fill="url(#spark-g-ig)"/>

</svg>
        `;
      }

      if (begrebId === 'wholeness') {
        return `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 380 640" role="img" aria-label="Wholeness">

<defs>
<style>
@keyframes core-r { 0%, 100% { r: 36px; } 50% { r: 46px; } }
@keyframes aura-r { 0%, 100% { rx: 158px; ry: 158px; } 50% { rx: 182px; ry: 182px; } }
@keyframes circle-whole { 0%, 100% { r: 108px; } 50% { r: 128px; } }
.core { animation: core-r 8s ease-in-out infinite; }
.aura { animation: aura-r 8s ease-in-out infinite; }
.circle-whole { animation: circle-whole 8s ease-in-out infinite; }
@media (prefers-reduced-motion: reduce) {
  .core, .aura, .circle-whole { animation: none; }
}
</style>
<radialGradient id="well-wh" cx="50%" cy="42%" r="65%">
<stop offset="0%" stop-color="#2a3847"/>
<stop offset="55%" stop-color="#1d2731"/>
<stop offset="100%" stop-color="#141b22"/>
</radialGradient>
<radialGradient id="core-g-wh" cx="50%" cy="50%" r="50%">
<stop offset="0%" stop-color="#faf4e8" stop-opacity="1"/>
<stop offset="30%" stop-color="#f0e2c8" stop-opacity="0.6"/>
<stop offset="70%" stop-color="#d4b98f" stop-opacity="0.15"/>
<stop offset="100%" stop-color="#c9b8a0" stop-opacity="0"/>
</radialGradient>
<radialGradient id="aura-g-wh" cx="50%" cy="50%" r="50%">
<stop offset="0%" stop-color="#e8dfcf" stop-opacity="0.28"/>
<stop offset="55%" stop-color="#a89880" stop-opacity="0.07"/>
<stop offset="100%" stop-color="#a89880" stop-opacity="0"/>
</radialGradient>
</defs>

<rect x="0" y="0" width="380" height="640" fill="url(#well-wh)"/>

<ellipse class="aura" cx="190" cy="270" rx="170" ry="170" fill="url(#aura-g-wh)"/>

<circle class="circle-whole" cx="190" cy="270" r="118" stroke="#faf4e8" stroke-width="0.9" fill="none" opacity="0.7"/>

<circle class="core" cx="190" cy="270" r="42" fill="url(#core-g-wh)"/>

</svg>
        `;
      }

      // Fallback: simple placeholder for other concepts
      return `
        <svg viewBox="0 0 380 640" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="${begrebId}">
          <rect x="0" y="0" width="380" height="640" fill="#2a3847"/>
          <text x="190" y="320" text-anchor="middle" font-family="Cormorant Garamond, serif" font-size="14" fill="#a89880" opacity="0.6">Motiv kommer snart</text>
        </svg>
      `;
    }

    // Render relations
    function renderRelations(relationsData, begrebId) {
      if (!relationsData || !relationsData[begrebId]) {
        return '';
      }

      const data = relationsData[begrebId];
      let html = '<section class="relations-section"><h2 class="section-heading">Relationer</h2>';

      // Hænger sammen med
      if (data.haenger_sammen_med && data.haenger_sammen_med.length > 0) {
        html += '<div class="relations-group">';
        html += '<h3 class="relations-subheading">Hænger sammen med</h3>';
        html += '<div class="pills-container">';
        data.haenger_sammen_med.forEach(rel => {
          // TODO: verificér med Niklas — skal vi fetche titler for relaterede enheder, eller er id nok?
          // For nu bruger vi id som fallback-navn
          const displayName = rel.id.replace(/-/g, ' ');
          html += `
            <span class="pill pill-dot">
              <span class="pill-marker pill-marker-dot"></span>
              ${displayName}
            </span>
          `;
        });
        html += '</div></div>';
      }

      // Lever også i
      if (data.lever_ogsaa_i && data.lever_ogsaa_i.length > 0) {
        html += '<div class="relations-group">';
        html += '<h3 class="relations-subheading">Lever også i</h3>';
        html += '<div class="pills-container">';
        data.lever_ogsaa_i.forEach(rel => {
          // TODO: verificér med Niklas — skal vi fetche titler for relaterede enheder, eller er id nok?
          const displayName = rel.id.replace(/-/g, ' ');
          html += `
            <span class="pill pill-square">
              <span class="pill-marker pill-marker-square"></span>
              ${displayName}
            </span>
          `;
        });
        html += '</div></div>';
      }

      html += '</section>';
      return html;
    }

    // Main render function
    async function renderBegreb(begrebId) {
      const container = document.getElementById('app-container');

      try {
        // Validate begrebId
        const filename = BEGREB_FILES[begrebId];
        if (!filename) {
          throw new Error(`Ugyldigt begreb-id: ${begrebId}`);
        }

        // Fetch markdown file
        const mdResponse = await fetch(`content/begreber/${filename}`);
        if (!mdResponse.ok) {
          throw new Error(`Kunne ikke loade ${filename}`);
        }
        const markdownText = await mdResponse.text();

        // Fetch relations
        const relResponse = await fetch(`relationer.json`);
        const relationsData = relResponse.ok ? await relResponse.json() : null;

        // Parse frontmatter and content
        const { frontmatter, content } = parseFrontmatter(markdownText);
        const sections = parseContent(content);

        // Generate HTML
        const gruppeLabel = GRUPPE_LABELS[frontmatter.gruppe] || frontmatter.gruppe.toUpperCase();
        const gruppeNummer = `${gruppeLabel} · ${frontmatter.nummer}`;

        let html = `
          <header class="top-nav">
            <button class="back-btn" onclick="window.location.href='begreber.html'">‹ Begreber</button>
            <span class="category-label">DE 18 BEGREBER</span>
          </header>

          <div class="subcategory-label">${gruppeNummer}</div>

          <div class="hero-container">
            ${generateHeroSVG(begrebId)}
          </div>

          <h1 class="main-title">${frontmatter.titel.toUpperCase()}</h1>
          <p class="subtitle">${frontmatter.undertitel}</p>

          <div class="divider"></div>
        `;

        // Intro text (always visible)
        if (sections['Intro']) {
          html += `<div class="intro-text">${marked.parse(sections['Intro'])}</div>`;
        }

        // Collapsible cards
        html += '<div class="cards-container">';

        // Iterate through sections (skip Intro, Relationer, Til refleksion)
        Object.keys(sections).forEach(sectionTitle => {
          if (sectionTitle === 'Intro' || sectionTitle === 'Relationer' || sectionTitle === 'Til refleksion') {
            return;
          }

          html += `
            <div class="card">
              <div class="card-header" onclick="toggleCard(this)">
                <span class="card-marker"></span>
                <span class="card-title">${sectionTitle}</span>
                <span class="chevron">▾</span>
              </div>
              <div class="card-content">
                ${marked.parse(sections[sectionTitle])}
              </div>
            </div>
          `;
        });

        html += '</div>';

        // Relations section
        html += renderRelations(relationsData, begrebId);

        // Reflection section
        if (sections['Til refleksion']) {
          html += `
            <section class="reflection-section">
              <h2 class="section-heading">Til refleksion</h2>
              <div class="reflection-content">
                ${marked.parse(sections['Til refleksion'])}
              </div>
            </section>
          `;
        }

        // Bottom navigation
        html += `
          <nav class="bottom-nav">
            <button class="nav-tab nav-tab-active" onclick="window.location.href='begreber.html'">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="3"/>
                <circle cx="6" cy="6" r="1.5"/>
                <circle cx="18" cy="6" r="1.5"/>
                <circle cx="6" cy="18" r="1.5"/>
                <circle cx="18" cy="18" r="1.5"/>
              </svg>
              <span class="nav-label">Modellen</span>
            </button>

            <button class="nav-tab" onclick="window.location.href='zoner.html'">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="6"/>
                <circle cx="12" cy="12" r="2"/>
              </svg>
              <span class="nav-label">Behandleren</span>
            </button>

            <button class="nav-tab" onclick="window.location.href='index.html'">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 18 Q 6 15, 9 12 T 15 9 T 21 6"/>
              </svg>
              <span class="nav-label">Rejsen</span>
            </button>

            <button class="nav-tab" onclick="window.location.href='index.html'">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="10" cy="12" r="4"/>
                <circle cx="14" cy="12" r="4"/>
                <circle cx="12" cy="9" r="4"/>
              </svg>
              <span class="nav-label">Inspiration</span>
            </button>
          </nav>
        `;

        // Update page title
        document.title = `${frontmatter.titel} — Den Biodynamiske App`;

        // Render
        container.innerHTML = html;

      } catch (error) {
        console.error('Fejl ved indlæsning:', error);
        container.innerHTML = `
          <div style="text-align: center; padding: 60px 20px;">
            <h1 style="font-family: var(--font-display); font-size: 24px; color: var(--text-primary); margin-bottom: 12px;">
              BEGREB IKKE FUNDET
            </h1>
            <p style="font-family: var(--font-body); font-size: 17px; color: var(--text-secondary); line-height: 1.75; margin-bottom: 24px;">
              Begrebet med id <strong>${begrebId}</strong> kunne ikke indlæses.
            </p>
            <button onclick="window.location.href='index.html'"
                    style="font-family: var(--font-body); font-size: 14px; font-style: italic;
                           color: var(--text-secondary); background: none; border: 1px solid var(--border-card);
                           border-radius: 8px; padding: 10px 20px; cursor: pointer;">
              Tilbage til forsiden
            </button>
          </div>
        `;
      }
    }

    // Card toggle function (same as in fulcrum.html)
    function toggleCard(header) {
      const card = header.parentElement;
      const content = card.querySelector('.card-content');
      const chevron = header.querySelector('.chevron');

      card.classList.toggle('open');

      if (card.classList.contains('open')) {
        chevron.style.transform = 'rotate(180deg)';
        content.style.maxHeight = content.scrollHeight + 'px';
      } else {
        chevron.style.transform = 'rotate(0deg)';
        content.style.maxHeight = '0';
      }
    }

    // Get begreb ID from URL and render
    const urlParams = new URLSearchParams(window.location.search);
    const begrebId = urlParams.get('id');

    if (!begrebId) {
      document.getElementById('app-container').innerHTML = `
        <div style="text-align: center; padding: 60px 20px;">
          <h1 style="font-family: var(--font-display); font-size: 24px; color: var(--text-primary); margin-bottom: 12px;">
            INTET BEGREB VALGT
          </h1>
          <p style="font-family: var(--font-body); font-size: 17px; color: var(--text-secondary); line-height: 1.75;">
            Tilføj <code>?id=fulcrum</code> til URL'en.
          </p>
        </div>
      `;
    } else {
      renderBegreb(begrebId);
    }
  </script>

  <script src="js/theme-toggle.js"></script>
</body>
</html>
